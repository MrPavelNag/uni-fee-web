THE_GRAPH_API_KEY=YOUR_THE_GRAPH_API_KEY
ENABLE_BASE_CHAIN=1
BASE_V3_ISOLATED_PIPELINE=0
V3_BASE_LIGHT_SCAN_PAGES=3
WEB_GRAPHQL_RETRIES=2
WEB_GRAPHQL_READ_TIMEOUT_SEC_NORMAL=30
WEB_GRAPHQL_CONNECT_TIMEOUT_SEC_NORMAL=8
WEB_GRAPHQL_READ_TIMEOUT_SEC_FAST=12
WEB_GRAPHQL_CONNECT_TIMEOUT_SEC_FAST=5
WEB_DISABLE_V4_SYMBOL_FALLBACK_NORMAL=1
WEB_V4_SKIP_CHAIN_AFTER_TIMEOUT=1
# Optional: set when you have a stable base v4 endpoint
# V4_OVERRIDE_BASE=https://<REAL_WORKING_BASE_V4_GRAPHQL_ENDPOINT>
